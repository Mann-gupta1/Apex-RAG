# Apex RAG environment configuration
# Copy to .env and adjust as needed

# ---- Application ----
APEX_ENV=local
APEX_LOG_LEVEL=INFO
APEX_DEFAULT_TENANT=default

# ---- Postgres + pgvector ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=apex
POSTGRES_PASSWORD=apex_dev_password
POSTGRES_DB=apex_rag
DATABASE_URL=postgresql+psycopg://apex:apex_dev_password@localhost:5432/apex_rag

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- Ollama (LLM) ----
OLLAMA_HOST=http://localhost:11434
OLLAMA_GENERATION_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_REWRITE_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=120

# ---- Embedding models (HuggingFace IDs) ----
TEXT_EMBED_MODEL=BAAI/bge-base-en-v1.5
IMAGE_EMBED_MODEL=ViT-B-32
IMAGE_EMBED_PRETRAINED=laion2b_s34b_b79k
RERANKER_MODEL=BAAI/bge-reranker-base
NLI_MODEL=cross-encoder/nli-deberta-v3-base

# ---- ASR / Diarization ----
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Optional: HF token for pyannote.audio diarization (leave empty to disable)
HUGGINGFACE_TOKEN=

# ---- Vector store driver: pgvector | weaviate ----
VECTOR_STORE_DRIVER=pgvector
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_PORT=50052

# ---- Phoenix tracing ----
PHOENIX_HOST=localhost
PHOENIX_PORT=6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
APEX_OTEL_ENABLED=true

# ---- API server ----
API_HOST=0.0.0.0
API_PORT=8000
GRPC_PORT=50051
GRAPHQL_PATH=/graphql
RATE_LIMIT_PER_MINUTE=60
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ---- Eval ----
EVAL_GOLDEN_PATH=data/eval_golden.json
EVAL_BASELINE_PATH=data/eval_baseline.json
EVAL_REGRESSION_THRESHOLD=0.05

# ---- Feature flags ----
ENABLE_HYDE=true
ENABLE_STEPBACK=true
ENABLE_MULTI_QUERY=true
ENABLE_RERANKER=true
ENABLE_CONTEXTUAL_RETRIEVAL=true
ENABLE_PII_REDACTION=true
