#!/bin/sh
# Strip Cursor attribution from commit messages (Co-authored-by / Made-with trailers).
MSG_FILE="$1"
if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi
sed -i.bak '/Co-authored-by: Cursor/d;/Made-with: Cursor/d;/Made with Cursor/d' "$MSG_FILE" 2>/dev/null || \
  sed -i '/Co-authored-by: Cursor/d;/Made-with: Cursor/d;/Made with Cursor/d' "$MSG_FILE" 2>/dev/null
rm -f "${MSG_FILE}.bak"
